#include <stdio.h>
#include <stdlib.h>
#include <locale.h>

int main(){
    int fd,td,i,j; //fd = first day , td = total day , j = gunun sayisal degeri
    system("COLOR F0");
    printf("(0)Pazartesi (1)Sali (2)Carsamba (3)Persembe (4)Cuma (5)Cumartesi (6)Pazar\n");
    printf("Ayin ilk gununu girin:\t"),scanf("%d",&fd);
    printf("Ay kac gun cekiyor:\t"),scanf("%d",&td);
    printf("\nPts Sal Car Per Cum Cts Paz\n");

    for(i=1;i<=fd;i++) 
        printf("    ");

    printf("  "); 
                  
    for(i=0,j=1;i<=6-fd;i++,j++){ 
        printf("%d",j);          
        printf("   ");}

    printf("\n");

    while(j<=td){                          
        for(i=0;i<=6;i++,j++){              
            if(j<10){                   
                printf("  ");            
                printf("%d",j);        
                printf(" ");}             
            else if(j<=td && j>=10){     
                printf(" ");            
                printf("%d",j);
                printf(" ");}}
        printf("\n");}
        main();
    return 0;}
